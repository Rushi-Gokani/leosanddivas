{% schema %}
{
  "name": "Image with Text split",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Image with Text"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post.</p>"
    },
    {
      "type": "image_picker",
      "id": "signature_image",
      "label": "Signature Image"
    },
    {
      "type": "text",
      "id": "signature",
      "label": "Signature Text (Fallback)",
      "default": "Founder Name"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Button"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "checkbox",
      "id": "reverse_mobile",
      "label": "Reverse on Mobile",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Image with Text split"
    }
  ]
}
{% endschema %}

{% style %}
  @font-face {
    font-family: "Super Playful";
    src: url('{{ "Super Playful.ttf" | asset_url }}') format("truetype");
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  /* Fallback for page-width if not globally defined */
  .page-width-custom {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  
  @media screen and (min-width: 750px) {
    .page-width-custom {
      /* padding: 0 5rem; */
    }
  }

  .image-text-custom-wrapper {
        display: flex;
        flex-direction: column;
        gap: 30px;
        align-items: center;
    }

  @media screen and (min-width: 750px) {
      .image-text-custom-wrapper {
          flex-direction: row;
          gap: 60px;
          align-items: center;
      }
      .image-text-custom-media, .image-text-custom-content {
          flex: 1;
          width: 50%;
      }
  }

  .image-text-custom-media {
    width: 100%;
  }

  .image-text-custom-media img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: var(--media-radius, 8px); 
  }

  .image-text-custom-content {
      width: 100%;
  }
  
  .image-text-custom-content h2 {
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: calc(var(--font-heading-scale) * 2rem);
  }
  
  .image-text-custom-content .button {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 1rem 2rem;
    text-decoration: none;
    background-color: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    border: none;
    border-radius: var(--button-radius, 0);
    margin-top: 1.5rem;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  
  .image-text-custom-content .button:hover {
     opacity: 0.8;
  }

  .image-text-custom-signature {
    font-family: "Super Playful", cursive; 
    font-size: 3.5rem; /* Increased size for signature look */
    margin-top: 1.5rem;
    font-weight: normal; 
    line-height: 1.2;
    transform: rotate(-3deg); /* Slight tilt for handwriting effect */
    display: inline-block;
    color: rgb(var(--color-foreground));
  }

  .image-text-custom-signature-img {
      display: block;
      margin-top: 1.5rem;
      max-width: 200px;
      height: auto;
  }

  /* Mobile Reverse Logic */
  @media screen and (max-width: 749px) {
      .image-text-custom-wrapper.reverse-mobile {
          flex-direction: column-reverse;
      }
  }
{% endstyle %}

<div class="color-{{ section.settings.color_scheme }}">
  <div class="page-width-custom section-{{ section.id }}-padding">
    <div class="image-text-custom-wrapper {% if section.settings.reverse_mobile %}reverse-mobile{% endif %}">
        <div class="image-text-custom-media">
            {% if section.settings.image != blank %}
                {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 50vw, 100vw' }}
            {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
        </div>
        <div class="image-text-custom-content">
            {% if section.settings.heading != blank %}
                <h2 class="h1">{{ section.settings.heading }}</h2>
            {% endif %}
            <div class="rte">
                {{ section.settings.content }}
            </div>
            {% if section.settings.signature_image != blank %}
                {{ section.settings.signature_image | image_url: width: 300 | image_tag: class: 'image-text-custom-signature-img', loading: 'lazy' }}
            {% elsif section.settings.signature != blank %}
                <div class="image-text-custom-signature">{{ section.settings.signature }}</div>
            {% endif %}
            {% if section.settings.button_label != blank %}
                <a href="{{ section.settings.button_link }}" class="button button--primary">
                    {{ section.settings.button_label }}
                </a>
            {% endif %}
        </div>
    </div>
  </div>
</div>
