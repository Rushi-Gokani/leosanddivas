
<script
  src="{{ 'testimonials.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<testimonials-component
  class="section spacing-style gap-style color-{{ section.settings.color_scheme }}"
  style="
    {%- render 'spacing-style', settings: section.settings %};
    {% render 'gap-style', value: section.settings.gap_between_testimonials, name: 'testimonials-gap' %}
    --testimonials-speed: {{ section.settings.scroll_speed }}s;
    --testimonials-pause-on-hover: {{ section.settings.pause_on_hover | default: false }};
    --testimonials-per-view: {{ section.settings.testimonials_per_view | default: 3 }};
    --testimonials-per-view-tablet: {{ section.settings.testimonials_per_view_tablet | default: 2 }};
    --testimonials-per-view-mobile: {{ section.settings.testimonials_per_view_mobile | default: 1 }};
  "
  data-auto-scroll="{{ section.settings.auto_scroll }}"
  data-scroll-direction="{{ section.settings.scroll_direction }}"
  data-scroll-speed="{{ section.settings.scroll_speed }}"
>
  {% if section.settings.heading != blank %}
    <div class="testimonials-section__header">
      <h2 class="testimonials-section__heading">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="testimonials-section__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="testimonials-wrapper" ref="wrapper">
    <div class="testimonials-track" ref="track">
      <div class="testimonials-content" ref="content">
        {% for block in section.blocks %}
          {% if block.type == 'testimonial' %}
            {% render 'testimonial-card', block: block %}
          {% endif %}
        {% endfor %}
      </div>
      {% if section.settings.auto_scroll %}
        <div class="testimonials-content testimonials-content--clone" ref="clone" aria-hidden="true">
          {% for block in section.blocks %}
            {% if block.type == 'testimonial' %}
              {% render 'testimonial-card', block: block %}
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>

  {% if section.settings.show_controls %}
    <div class="testimonials-controls">
      <button class="testimonials-control testimonials-control--prev" ref="prevButton" aria-label="Previous testimonials">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>
      <button class="testimonials-control testimonials-control--next" ref="nextButton" aria-label="Next testimonials">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </button>
    </div>
  {% endif %}
</testimonials-component>

{% stylesheet %}
  testimonials-component {
    display: block;
    width: 100%;
    position: relative;
  }

  .testimonials-section__header {
    text-align: center;
    margin-bottom: var(--spacing-lg, 2rem);
  }

  .testimonials-section__heading {
    font-size: var(--font-size--h2, 2rem);
    margin-bottom: var(--spacing-xs, 0.5rem);
    letter-spacing: 2.4px;
  }

  .testimonials-section__subheading {
    font-size: var(--font-size--body, 1rem);
    opacity: 0.8;
  }

  .testimonials-wrapper {
    overflow: hidden;
    position: relative;
    width: 100%;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 5%,
      black 95%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 5%,
      black 95%,
      transparent 100%
    );
  }

  @media (max-width: 749px) {
    .testimonials-wrapper {
      mask-image: none;
      -webkit-mask-image: none;
    }
  }

  .testimonials-track {
    display: flex;
    gap: var(--testimonials-gap, 1.5rem);
    will-change: transform;
  }

  .testimonials-content {
    display: flex;
    gap: var(--testimonials-gap, 1.5rem);
    min-width: max-content;
  }

  .testimonials-content--clone {
    display: flex;
    gap: var(--testimonials-gap, 1.5rem);
  }

  .testimonial-card {
    width: calc((100vw - var(--section-padding-inline, 0px) * 2 - (var(--testimonials-per-view, 3) - 1) * var(--testimonials-gap, 1.5rem)) / var(--testimonials-per-view, 3));
    min-width: 280px;
    max-width: 400px;
  }

  @media (min-width: 990px) {
    .testimonial-card {
      width: calc((100% - (var(--testimonials-per-view, 3) - 1) * var(--testimonials-gap, 1.5rem)) / var(--testimonials-per-view, 3));
    }
  }

  @media (max-width: 989px) and (min-width: 750px) {
    .testimonial-card {
      width: calc((100% - (var(--testimonials-per-view-tablet, 2) - 1) * var(--testimonials-gap, 1.5rem)) / var(--testimonials-per-view-tablet, 2));
    }
  }

  @media (max-width: 749px) {
    .testimonial-card {
      width: calc(100vw - var(--section-padding-inline, 0px) * 2 - var(--testimonials-gap, 1.5rem));
      min-width: 280px;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    testimonials-component[data-auto-scroll="true"] .testimonials-track {
      animation: testimonials-scroll var(--testimonials-speed, 30s) linear infinite;
    }

    testimonials-component[data-auto-scroll="true"][data-scroll-direction="reverse"] .testimonials-track {
      animation-direction: reverse;
    }

    testimonials-component[data-auto-scroll="true"]:hover .testimonials-track {
      animation-play-state: paused;
    }
  }

  @keyframes testimonials-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50% - var(--testimonials-gap, 1.5rem) / 2));
    }
  }

  .testimonials-controls {
    display: flex;
    justify-content: center;
    gap: var(--spacing-sm, 1rem);
    margin-top: var(--spacing-lg, 2rem);
  }

  .testimonials-control {
    background: var(--color-background);
    border: 2px solid var(--color-foreground);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    color: var(--color-foreground);
  }

  .testimonials-control:hover {
    background: var(--color-foreground);
    color: var(--color-background);
    transform: scale(1.1);
  }

  .testimonials-control:active {
    transform: scale(0.95);
  }

  .testimonials-control svg {
    width: 24px;
    height: 24px;
  }

  @media (max-width: 749px) {
    .testimonials-section__heading {
      font-size: var(--font-size--h3, 1.5rem);
    }

    .testimonials-controls {
      margin-top: var(--spacing-md, 1.5rem);
    }
  }
{% endstylesheet %}

