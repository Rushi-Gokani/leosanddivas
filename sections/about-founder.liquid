<style>
  @font-face {
    font-family: 'BrittanySignature';
    src: url('https://cdn.shopify.com/s/files/1/0783/2200/8287/files/BrittanySignature.ttf?v=1773123403') format('truetype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Allura';
    src: url('https://cdn.shopify.com/s/files/1/0783/2200/8287/files/Allura-Regular.ttf?v=1773123701') format('truetype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
