{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Great+Vibes&family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Lato:ital,wght@0,300;0,400;1,300&display=swap');

  .about-founder-section {
    background-color: {{ section.settings.bg_color }};
    {% if section.settings.bg_image != blank %}
    background-image: url('{{ section.settings.bg_image | img_url: 'master' }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    {% endif %}
    color: {{ section.settings.text_color }};
    padding: 60px 20px;
    position: relative;
    overflow: hidden;
    font-family: 'Lato', sans-serif;
  }
  
  /* Subtle texture effect using CSS */
  .about-founder-section::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: radial-gradient(#d3c6bc 1px, transparent 1px);
    background-size: 20px 20px;
    opacity: 0.2;
    pointer-events: none;
    z-index: 1;
  }

  .about-founder-container {
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .about-founder-header {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 50px;
  }

  .about-founder-header .line-ornament {
    height: 1px;
    background-color: {{ section.settings.text_color }};
    opacity: 0.3;
    flex: 1;
    max-width: 150px;
    margin: 0 20px;
    position: relative;
  }
  
  .about-founder-header .line-ornament::after {
    content: '';
    position: absolute;
    top: -2px;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: {{ section.settings.text_color }};
  }
  .about-founder-header .line-ornament:first-child::after { right: 0; }
  .about-founder-header .line-ornament:last-child::after { left: 0; }

  .about-founder-title {
    font-family: 'Allura', cursive !important;
    font-size: 56px;
    font-weight: 400;
    margin: 0;
    color: {{ section.settings.text_color }};
  }

  /* Block 1 */
  .about-founder-block1 {
    display: flex;
    flex-wrap: wrap;
    gap: 40px;
    margin-bottom: 80px;
    align-items: flex-start;
  }

  .about-founder-image-col {
    flex: 1 1 400px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .founder-img-wrapper {
    position: relative;
    width: 100%;
    max-width: 480px;
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
  }
  
  .founder-img-wrapper img {
    border-radius: 12px;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    display: block;
  }

  .founder-socials-overlay {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    z-index: 2;
  }

  .social-icons-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 5px;
  }

  .follow-journey-text {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 18px;
    margin: 0 0 10px 0;
    color: {{ section.settings.text_color }};
  }

  .social-icons {
    display: flex;
    gap: 10px;
    justify-content: center;
  }

  .social-icons a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    background-color: {{ section.settings.text_color | color_modify: 'alpha', 0.8 }};
    color: #ffffff;
    border-radius: 50%;
    text-decoration: none;
    transition: transform 0.3s ease, background-color 0.3s ease;
  }
  
  .social-icons a:hover {
    transform: translateY(-2px);
    background-color: {{ section.settings.text_color }};
  }

  .social-icons a svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .founder-signature-overlay {
    font-family: 'BrittanySignature', cursive !important;
    font-size: 38px;
    line-height: 1;
    color: {{ section.settings.text_color }};
    display: block;
    margin-bottom: 5px;
  }

  .about-founder-text-col {
    flex: 1 1 400px;
    padding-top: 20px;
  }

  .founder-name {
    font-family: 'Playfair Display', serif;
    font-size: 36px;
    margin: 0 0 8px 0;
    color: {{ section.settings.text_color }};
  }

  .founder-role {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 18px;
    margin: 0 0 25px 0;
    opacity: 0.8;
    letter-spacing: 0.5px;
  }

  .founder-bio {
    font-size: 16px;
    line-height: 1.8;
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.9 }};
  }
  
  .founder-bio p {
    margin-bottom: 20px;
  }

  /* Block 2 */
  .about-founder-block2 {
    margin-bottom: 60px;
  }

  .from-heart-title {
    font-family: 'Allura', cursive !important;
    font-size: 52px;
    font-weight: 400;
    margin: 0 0 20px 0;
    text-align: center;
    color: {{ section.settings.text_color }};
  }

  .heart-content-wrapper {
    background-color: rgba(255, 255, 255, 0.45);
    border-radius: 12px;
    padding: 30px;
    display: flex;
    flex-wrap: wrap;
    gap: 40px;
    align-items: stretch;
    box-shadow: 0 10px 40px rgba(0,0,0,0.03);
    border: 1px solid rgba(255,255,255,0.6);
  }

  .heart-image-col {
    flex: 1 1 300px;
    display: flex;
    align-items: center;
  }

  .heart-image-col img {
    border-radius: 12px 12px 12px 40px;
    width: 100%;
    height: auto;
    object-fit: cover;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .heart-text-col {
    flex: 1 1 400px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .quote-text {
    font-size: 16px;
    line-height: 1.8;
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.9 }};
    position: relative;
    padding-left: 20px;
  }
  
  .quote-text::before {
    content: "“";
    position: absolute;
    top: -10px;
    left: -15px;
    font-family: 'Playfair Display', serif;
    font-size: 60px;
    color: {{ section.settings.text_color }};
    opacity: 0.3;
    line-height: 1;
  }
  
  .quote-text::after {
    content: "”";
    display: inline-block;
    font-family: 'Playfair Display', serif;
    font-size: 60px;
    color: {{ section.settings.text_color }};
    opacity: 0.3;
    line-height: 0;
    vertical-align: bottom;
    margin-left: 5px;
    transform: translateY(15px);
  }

  .signature-right {
    font-family: 'BrittanySignature', cursive !important;
    font-size: 40px;
    text-align: right;
    margin-top: 20px;
    color: {{ section.settings.text_color }};
  }

  /* Bottom Footer */
  .about-founder-footer {
    text-align: center;
    border-top: 1px solid rgba(0,0,0,0.05);
    padding-top: 40px;
    margin-top: 40px;
  }

  .footer-tagline {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 26px;
    margin-bottom: 15px;
  }

  .footer-tagline .heart-icon {
    font-style: normal;
    color: #cda899;
  }

  .footer-categories {
    font-size: 16px;
    letter-spacing: 1px;
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .about-founder-block1, .heart-content-wrapper {
      flex-direction: column;
      gap: 30px;
    }
    .about-founder-title { font-size: 36px; }
    .founder-name { font-size: 28px; }
    .from-heart-title { font-size: 32px; }
  }
{%- endstyle -%}

<div class="about-founder-section">
  <div class="about-founder-container">
    
    <div class="about-founder-header">
      <div class="line-ornament"></div>
      <h2 class="about-founder-title">{{ section.settings.main_heading }}</h2>
      <div class="line-ornament"></div>
    </div>

    <!-- First Block -->
    <div class="about-founder-block1">
      <div class="about-founder-image-col">
        <div class="founder-img-wrapper">
          {% if section.settings.image_1 %}
            <img src="{{ section.settings.image_1 | img_url: '800x' }}" alt="{{ section.settings.name }}" loading="lazy">
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
          
          <div class="founder-socials-overlay">
            <span class="founder-signature-overlay">{{ section.settings.name }}</span>
            <div class="social-icons-block">
              <p class="follow-journey-text">{{ section.settings.social_heading }}</p>
              <div class="social-icons">
