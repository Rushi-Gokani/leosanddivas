            {% if section.settings.social_facebook != blank %}<a href="{{ section.settings.social_facebook }}" aria-label="Facebook"><svg viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-3 7h-1.924c-.615 0-1.076.252-1.076.889v1.111h3l-.239 3h-2.761v8h-3v-8h-2v-3h2v-1.923c0-2.022 1.064-3.077 3.461-3.077h2.539v3z"/></svg></a>{% endif %}
            {% if section.settings.social_pinterest != blank %}<a href="{{ section.settings.social_pinterest }}" aria-label="Pinterest"><svg viewBox="0 0 24 24"><path d="M12 0c-6.627 0-12 5.372-12 12 0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.923 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.55.535 6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg></a>{% endif %}
            {% if section.settings.social_email != blank %}<a href="mailto:{{ section.settings.social_email }}" aria-label="Email"><svg viewBox="0 0 24 24"><path d="M0 3v18h24v-18h-24zm21.518 2l-9.518 7.713-9.518-7.713h19.036zm-19.518 14v-11.817l10 8.104 10-8.104v11.817h-20z"/></svg></a>{% endif %}
            {% if section.settings.social_youtube != blank %}<a href="{{ section.settings.social_youtube }}" aria-label="YouTube"><svg viewBox="0 0 24 24"><path d="M21.582 6.186c-.23-.86-.908-1.538-1.768-1.768C18.254 4 12 4 12 4s-6.254 0-7.814.418c-.86.23-1.538.908-1.768 1.768C2 7.746 2 12 2 12s0 4.254.418 5.814c.23.86.908 1.538 1.768 1.768C5.746 20 12 20 12 20s6.254 0 7.814-.418c.86-.23 1.538-.908 1.768-1.768C22 16.254 22 12 22 12s0-4.254-.418-5.814zM10 15V9l5.2 3-5.2 3z"/></svg></a>{% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <div class="about-founder-text-col">
        <h3 class="founder-name">{{ section.settings.name }}</h3>
        <p class="founder-role">{{ section.settings.role }}</p>
        <div class="founder-bio">
          {{ section.settings.bio_text }}
        </div>
      </div>
    </div>

    <!-- Second Block -->
    <div class="about-founder-block2">
      <h3 class="from-heart-title">{{ section.settings.second_heading }}</h3>
      
      <div class="heart-content-wrapper">
        <div class="heart-image-col">
           {% if section.settings.image_2 %}
             <img src="{{ section.settings.image_2 | img_url: '800x' }}" alt="From my heart to yours" loading="lazy">
           {% else %}
             {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
           {% endif %}
        </div>
        <div class="heart-text-col">
           <div class="quote-text">{{ section.settings.quote_text }}</div>
           <div class="signature-right">- {{ section.settings.name }}</div>
        </div>
      </div>
    </div>

    <!-- Bottom Footer -->
    <div class="about-founder-footer">
      <div class="footer-tagline">
        {{ section.settings.footer_tagline }} <span class="heart-icon">♥</span>
      </div>
      <div class="footer-categories">
        {{ section.settings.categories }}
      </div>
    </div>

  </div>
</div>

