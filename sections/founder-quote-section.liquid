{%- style -%}
  .founder-quote-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | img_url: 'master' }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}

    padding-bottom: {{ section.settings.padding_bottom }}px;
    position: relative;
    overflow: hidden;
  }

  .founder-quote-container {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 0px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* Main Image Styling with Faded Edges */
  .founder-quote-image-wrapper {
    position: relative;
    width: 100%;
    max-width: 100%;
    margin-bottom: 40px;
  }

  .founder-quote-image-wrapper img {
    width: 100%;
    display: block;
    height: auto;
    /* Creating a soft edge effect with a focus on the bottom fade */
    mask-image: linear-gradient(to bottom, black 80%, transparent 100%), 
                radial-gradient(ellipse at center, black 60%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%), 
                        radial-gradient(ellipse at center, black 60%, transparent 100%);
    mask-composite: intersect;
    -webkit-mask-composite: source-in;
  }

  /* Quote Styling */
  .founder-quote-content {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
  }

  .founder-quote-text {
    font-family: 'Playfair Display', serif;
    font-size: {{ section.settings.quote_font_size }}px;
    line-height: 1.4;
    color: {{ section.settings.text_color }};
    margin: 0;
    font-style: italic;
    font-weight: 400;
  }

  .founder-quote-text::before {
    content: "“ ";
    font-size: 1.2em;
  }
  
  .founder-quote-text::after {
    content: " ”";
    font-size: 1.2em;
  }

  /* Attribution / Author Styling */
  .founder-quote-author {
    margin-top: 25px;
    font-family: 'Playfair Display', serif;
    font-size: {{ section.settings.author_font_size }}px;
    color: {{ section.settings.text_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    opacity: 0.9;
  }

  .founder-quote-author .author-dash {
    margin-right: 5px;
  }

  .founder-quote-author .heart-icon {
    display: inline-flex;
    color: {{ section.settings.heart_color }};
    font-size: 0.9em;
  }

  @media (max-width: 768px) {
    .founder-quote-text {
      font-size: clamp(20px, 5vw, 26px);
    }
    .founder-quote-image-wrapper {
      margin-bottom: 30px;
    }
    .founder-quote-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
    }
  }
{%- endstyle -%}

<section class="founder-quote-{{ section.id }} section-{{ section.id }}-padding">
  <div class="founder-quote-container">
    
    {% if section.settings.main_image != blank %}
      <div class="founder-quote-image-wrapper">
        <img 
          src="{{ section.settings.main_image | img_url: '1200x' }}" 
          alt="{{ section.settings.author_name }}"
          loading="lazy"
          width="{{ section.settings.main_image.width }}"
          height="{{ section.settings.main_image.height }}"
        >
      </div>
    {% endif %}

    <div class="founder-quote-content">
      {% if section.settings.quote_text != blank %}
        <p class="founder-quote-text">
          {{ section.settings.quote_text | escape }}
        </p>
      {% endif %}

      <div class="founder-quote-author">
        <span class="author-dash">—</span>
        <span class="author-name">{{ section.settings.author_name }}</span>
        {% if section.settings.author_role != blank %}
          <span class="author-separator">,</span>
          <span class="author-role">{{ section.settings.author_role }}</span>
        {% endif %}
        <span class="heart-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
        </span>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Founder Quote",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdf8f4"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Quote Text",
      "default": "A little corner of my heart — where motherhood, love & learning come together."
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author Name",
      "default": "Debina"
    },
    {
      "type": "text",
      "id": "author_role",
      "label": "Author Role",
      "default": "Founder"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#593c39"
    },
    {
      "type": "color",
      "id": "heart_color",
      "label": "Heart Icon Color",
      "default": "#e6ccb2"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "quote_font_size",
      "min": 20,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Quote Font Size",
      "default": 32
    },
    {
      "type": "range",
      "id": "author_font_size",
      "min": 14,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Author Font Size",
      "default": 18
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Founder Quote"
    }
  ]
}
{% endschema %}
